@page "/forms"
@using Microsoft.EntityFrameworkCore
@using Study_Tracker_BlazorApp.Data
@using Study_Tracker_BlazorApp.Services
@using Study_Tracker_BlazorApp.Models
@inject TaskService TaskService
@inject DatabaseService DatabaseService
@inject NavigationManager Navigation


@using SqliteWasmHelper  
@inject ISqliteWasmDbContextFactory<AppDbContext> DbFactoryContext

<PageTitle>Organize Tasks</PageTitle>

<div class="tracker-container">
    <div class="header">
        <h1>📘 CRUD Study Tracker <span class="za-badge">🇿🇦 No JavaScript</span></h1>
        <div class="sub">Complete Create · Read · Update · Delete Interface | Pure HTML/CSS Demo</div>
    </div>

    <!-- Stats summary (static but shows CRUD concept) -->
    <div class="stats-grid">
        <div class="stat-card"><div class="stat-number">6</div><div class="stat-label">Total Tasks</div></div>
        <div class="stat-card"><div class="stat-number">2</div><div class="stat-label">Completed ✓</div></div>
        <div class="stat-card"><div class="stat-number">4</div><div class="stat-label">In Progress</div></div>
        <div class="stat-card"><div class="stat-number">🎯 CRUD</div><div class="stat-label">Full Control</div></div>
    </div>

    <div class="crud-layout">
        <!-- CREATE / UPDATE PANEL - Manual form for adding/editing tasks (No JS, just UI) -->
        <div class="form-panel">
            <div class="section-title">✏️ Create / Edit Study Task</div>
            <form action="#" method="get" id="createTaskForm">
                <!-- Hidden fields to simulate edit mode (pure HTML/CSS) -->
                <div class="form-group">
                    <label>📌 Task Title *</label>
                    <input type="text" @bind="newTodoTitle" placeholder="Enter a new task..." @onkeypress="OnKeyPress" />
                </div>
                <div class="form-group">
                    <label>📚 Subject / Module</label>
                    <input type="text" name="subject" placeholder="Mathematics, Science..." @bind="newSubject">
                </div>
                <div class="form-group">
                    <label>⏱️ Estimated time</label>
                    <input type="text" name="time" placeholder="e.g., 45 min" @bind="newEstimatedTime">
                </div>
                <div class="form-group">
                    <label>⭐ Priority</label>
                    <select name="priority" @bind="newPriority">
                        <option value="High">🔥 High</option>
                        <option value="Medium" selected>⚡ Medium</option>
                        <option value="Low">🍃 Low</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>✅ Status</label>
                    <select name="status" @bind="newIsCompleted">
                        <option value="False">⏳ Pending</option>
                        <option value="True">🎉 Completed</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>📝 Notes</label>
                    <textarea name="notes" rows="2" @bind="newNotes" placeholder="Additional details...">Focus on past papers</textarea>
                </div>
                <div>
                    <button type="button" class="btn btn-primary" @onclick="AddTodo" disabled="@string.IsNullOrWhiteSpace(newTodoTitle)">➕ Add New Task (Demo)</button>
                    <button type="reset" class="btn btn-secondary">🗑️ Clear Form</button>
                </div>
            </form>
            <div class="info-note">
                💡 <strong>CRUD Without JS:</strong> Use the form above to design new tasks. For a real backend, this data would be saved to a database. This demo shows the UI/UX of a full CRUD system.
            </div>
        </div>

        <!-- READ / UPDATE / DELETE PANEL - Task list with inline edit/delete links -->
        <div class="list-panel">
            <div class="section-title">📋 Study Task List (CRUD Operations)</div>

            <!-- Search/filter UI (visual only) -->
            <div class="search-box">
                <input type="text" placeholder="🔍 Search by title or subject... (visual filter demo)">
                <select>
                    <option>All Tasks</option>
                    <option>Pending</option>
                    <option>Completed</option>
                </select>
            </div>

            <div style="overflow-x: auto;">
                <table class="task-table">
                    <thead>
                        <tr><th>Title</th><th>Subject</th><th>Time</th><th>Priority</th><th>Status</th><th>Actions (CRUD)</th></tr>
                    </thead>
                    <tbody>

                        @foreach (var taskitem in TaskItems)
                        {
                            <!-- Read / Update / Delete demonstration -->
                            <tr>
                                <td><strong>@taskitem.Title</strong></td>
                                <td><span class="badge-subject">@taskitem.Subject</span></td>
                                <td>@taskitem.EstimatedTime</td>
                                <td>@taskitem.Priority</td>
                                <td>@taskitem.IsCompleted</td>
                                <td class="action-links">
                                    <a href="#edit-task-1" class="edit-link">✏️ Edit</a>
                                    <a href="/forms" class="delete-link" @onclick="() => DeleteTaskItem(taskitem.Id)">🗑️ Delete</a>
                                </td>
                            </tr>
                        }

                        
                    </tbody>
                </table>
            </div>

            <!-- Edit section simulation (inline edit forms for each task, demonstrating UPDATE) -->
            <div style="margin-top: 2rem; background: #fef2e8; border-radius: 1.5rem; padding: 1rem;">
                <div class="section-title" style="font-size: 1.2rem;">✏️ Update Task (Edit Example)</div>
                <p style="margin-bottom: 10px; font-size:0.85rem;">Click any "Edit" link above to jump — here's a pre-filled edit form for <strong>"Mathematics Revision"</strong></p>
                <form action="#" method="get">
                    <div style="display: flex; flex-wrap: wrap; gap: 12px;">
                        <input type="text" value="Complete Functions & Graphs" style="flex:2;" placeholder="Title">
                        <input type="text" value="Mathematics" style="flex:1;" placeholder="Subject">
                        <input type="text" value="1.5 hours" style="flex:1;" placeholder="Time">
                        <select style="flex:1;">
                            <option>High</option>
                            <option selected>Medium</option>
                            <option>Low</option>
                        </select>
                        <select style="flex:1;">
                            <option selected>Pending</option>
                            <option>Completed</option>
                        </select>
                        <button type="submit" class="btn btn-primary" style="padding: 6px 16px;">💾 Update Task (Demo)</button>
                    </div>
                    <div class="info-note" style="margin-top: 8px;">✅ This demonstrates the UPDATE operation in CRUD. Modify fields and click update (UI demo without backend).</div>
                </form>
            </div>


        </div>
    </div>

    <!-- CREATE additional quick-add example -->
    <div class="motivation-card">
        <div class="quote-text">
            📚 <strong>CRUD Study Tracker - South African Student Edition</strong><br>
            Create, Read, Update, Delete your study plans. No JavaScript needed — pure HTML/CSS interface with functional forms.
        </div>
        <div class="flag-emojis" style="font-size: 1.8rem;">🇿🇦 ✨📖</div>
    </div>



    <!-- Additional READ-only statistics and info -->
    <div class="footer-note">
        <div style="display: flex; justify-content: space-between; flex-wrap: wrap;">
            <span>✅ <strong>CRUD Operations:</strong> Create (Add forms) | Read (Table list) | Update (Edit links & forms) | Delete (Delete buttons)</span>
            <span>📌 No JavaScript — 100% HTML5 & CSS3</span>
        </div>
        <hr>
        <div>📖 Study Tracker CRUD Page — Designed for Mzansi learners. Use the forms and action buttons to simulate full data management. Ideal for demonstrating backend-ready interface.</div>
        <div style="margin-top: 8px;">🇿🇦 "Education is the great engine of personal development." — Nelson Mandela</div>
    </div>
</div>


@code {
    private List<TaskItem> TaskItems = new();
    private bool isLoading = false;
    private bool showModal = false;
    private TaskItem? editingTaskItem = null;

    private string newTodoTitle = string.Empty;
    private string newSubject = string.Empty;
    private string newEstimatedTime = string.Empty;
    private string newPriority = "medium";
    private string newNotes = string.Empty;
    private bool newIsCompleted = false;
    public int newId = 1;
  

    protected override async Task OnInitializedAsync()
    {
        await LoadTaskItems();
    }


    //read all
    private async Task LoadTaskItems()
    {
        isLoading = true;
        await using var context = await DbFactoryContext.CreateDbContextAsync();
        TaskItems = await context.TaskItems.ToListAsync();
        isLoading = false;
    }

    // DELETE Single task
    private async Task DeleteTaskItem(int id)
    {
      
            var success = await TaskService.DeleteTaskAsync(id);
   
            await LoadTaskItems();
            
        
    }



 

    private void CloseModal()
    {
        showModal = false;
        editingTaskItem = null;
        StateHasChanged();
    }

    private async Task AddTodo()
    {
        if (string.IsNullOrWhiteSpace(newTodoTitle)){
            return;
        }

        var task = new TaskItem
            {
                Title = newTodoTitle.Trim(),
                CreatedAt = DateTime.Now,
                Subject = newSubject,
                EstimatedTime = newEstimatedTime,
                Priority = newPriority,
                IsCompleted = newIsCompleted,
                Notes= newNotes
            };

        await using var context = await DbFactoryContext.CreateDbContextAsync();
        context.TaskItems.Add(task);
        await context.SaveChangesAsync();
        newTodoTitle = string.Empty;
        await LoadTaskItems();

    }

    private async Task OnKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(newTodoTitle))
        {
            await AddTodo();
        }
    }
}

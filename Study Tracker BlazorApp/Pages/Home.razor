@page "/"
@using Microsoft.EntityFrameworkCore
@using Study_Tracker_BlazorApp.Services
@using Study_Tracker_BlazorApp.Models
@inject TaskService TaskService
@inject DatabaseService DatabaseService
@inject NavigationManager Navigation
@using Study_Tracker_BlazorApp.Data
@using SqliteWasmHelper
@inject ISqliteWasmDbContextFactory<AppDbContext> DbFactoryContext


<PageTitle>Home</PageTitle>

<div class="tracker-container">
    <div class="header">
        <h1>📘 Study Tracker <span class="za-badge">🇿🇦 Mzansi Focus</span></h1>
        <div class="sub">No login required · Track your study goals & weekly progress</div>
    </div>

    <!-- Stats Cards – manual but motivating (shows max targets, user fills by checking tasks) -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-number">📚 8+</div>
            <div class="stat-label">Topics</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">✅ 0 / 24</div>
            <div class="stat-label">Tasks Completed</div>
        </div>

    </div>

    <!-- Main Tracker area: Weekly study plan + Today's tasks (no JS checkboxes) -->
    <div class="dashboard-split">
        <!-- LEFT PANEL: Weekly Study Schedule (Checklist) -->
       
        
        <!-- TaskItems Table-->
       @if (isLoading == true)
        {
            <div class="text-center">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (TaskItems.Count == 0)
        {
            <div class="alert alert-info">
                No Subjects found. Click Organize Tasks to get started!
            </div>
        }
        else
        {
            <div class="plan-panel">
                <div class="section-title">📅 Weekly Study Plan</div>
                <table class="study-table" >
                    <thead>
                        <tr><th>Topic</th><th>Subject</th><th>Time</th><th>Priority</th><th>Notes</th><th class="checkbox-cell">Done✓</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var taskitem in TaskItems){
                            
                            <tr>
                                
                                <td><strong>@taskitem.Title</strong></td>
                                <td><span class="badge-subject">@taskitem.Subject</span></td>
                                <td>@taskitem.EstimatedTime</td>
                                <td>@taskitem.Priority</td>
                                <td>@taskitem.Notes</td>
                               
                                <td>
                                        <input type="checkbox" 
                                        checked="@taskitem.IsCompleted" 
                                        onchange="@(() =>UpdateTaskItem(taskitem))" />
                                </td>
                                
                            </tr>
                        }

                    </tbody>
                </table>




                <div class="manual-progress">
                    💡 Tip: Tick the checkboxes as you complete each study session. No account needed — your progress stays on this page.
                </div>
            </div>

        }
   
    </div>

    <!-- Extra resources + Motivational message for South African students -->
    <div class="motivation-card">
        <div class="quote-text">
            🌟 <strong>"Education is the most powerful weapon"</strong> — Nelson Mandela<br>
            Keep pushing, future leader! Every study session brings you closer to your dreams.
        </div>
        <div class="flag-emojis">🇿🇦 ✨ 📖</div>
    </div>





    <!-- progress summary via a simple manual total (NO JS, but we use static representation) -->
    <div class="footer-note">
        <div style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
            <span>✨ Track your daily goals: tick off subjects</span>
            <span>📚 #StudySmart #Matric2026 #SouthAfrica</span>
            <span>⏲️ Recommended: 25 min study + 5 min break</span>
        </div>
        <hr style="margin: 0.8rem 0;">
        <div>Study Tracker App – designed for SA learners. No sign-up, no distractions..</div>
    </div>
</div>

@code {
    private List<TaskItem> TaskItems = new();
    private bool isLoading = false;
    private bool showModal = false;
   
    protected override async Task OnInitializedAsync()
    {
        await LoadTaskItems();
    } 

    //Read all
    private async Task LoadTaskItems()
    {
        isLoading = true;
        await using var context = await DbFactoryContext.CreateDbContextAsync(); 
        TaskItems = await context.TaskItems.ToListAsync();

        isLoading = false;
        //StateHasChanged();
    }


    // Update Single task
    private async Task UpdateTaskItem(TaskItem? edittingItem)
    {

        edittingItem.IsCompleted = !edittingItem.IsCompleted;

        var success = await TaskService.UpdateTaskAsync(edittingItem.Id, edittingItem.Title, edittingItem.Subject, edittingItem.EstimatedTime, edittingItem.Priority, edittingItem.Notes, edittingItem.IsCompleted);

        await LoadTaskItems();


    }

}
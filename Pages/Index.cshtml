@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="tracker-container">
    <div class="header">
        <h1>📘 Study Tracker <span class="za-badge">🇿🇦 Mzansi Focus</span></h1>
        <div class="sub">No login required · Track your study goals & weekly progress</div>
    </div>

    <!-- Stats Cards – manual but motivating (shows max targets, user fills by checking tasks) -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-number">📚 8+</div>
            <div class="stat-label">Subjects Ready</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">✅ 0 / 24</div>
            <div class="stat-label">Tasks Completed<br>(tick boxes)</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">⏱️ 2h/day</div>
            <div class="stat-label">Daily Goal</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">🏆 85%</div>
            <div class="stat-label">Attendance</div>
        </div>
    </div>

    <!-- Main Tracker area: Weekly study plan + Today's tasks (no JS checkboxes) -->
    <div class="dashboard-split">
        <!-- LEFT PANEL: Weekly Study Schedule (Checklist) -->
        <div class="plan-panel">
            <div class="section-title">📅 Weekly Study Plan</div>
            <table class="study-table">
                <thead>
                    <tr><th>Day</th><th>Subject / Topic</th><th>Time</th><th class="checkbox-cell">Done ✓</th></tr>
                </thead>
                <tbody>
                    <!-- Monday -->
                    <tr><td>Mon</td><td><span class="subject-badge">Mathematics</span> - Algebra & Functions</td><td>15:00–16:30</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <tr><td>Mon</td><td><span class="subject-badge">English</span> - Essay writing</td><td>17:00–18:00</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <!-- Tuesday -->
                    <tr><td>Tue</td><td><span class="subject-badge">Physical Science</span> - Mechanics</td><td>14:30–16:00</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <tr><td>Tue</td><td><span class="subject-badge">Life Orientation</span> - Study skills</td><td>16:30–17:30</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <!-- Wednesday -->
                    <tr><td>Wed</td><td><span class="subject-badge">Mathematics</span> - Trigonometry</td><td>15:00–16:30</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <tr><td>Wed</td><td><span class="subject-badge">History</span> - Apartheid & Democracy SA</td><td>17:00–18:15</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <!-- Thursday -->
                    <tr><td>Thu</td><td><span class="subject-badge">Geography</span> - Climatology</td><td>14:30–15:45</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <tr><td>Thu</td><td><span class="subject-badge">English</span> - Poetry analysis</td><td>16:00–17:00</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <!-- Friday -->
                    <tr><td>Fri</td><td><span class="subject-badge">Physical Science</span> - Chemistry revision</td><td>15:00–16:30</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <tr><td>Fri</td><td><span class="subject-badge">Mathematics</span> - Past paper practice</td><td>17:00–18:30</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <!-- Weekend catch-up -->
                    <tr><td>Sat</td><td><span class="subject-badge">Revision / weak topics</span> - Self study</td><td>09:00–11:00</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <tr><td>Sun</td><td><span class="subject-badge">Rest & Plan</span> - Weekly review</td><td>16:00–17:00</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                </tbody>
            </table>
            <div class="manual-progress">
                💡 Tip: Tick the checkboxes as you complete each study session. No account needed — your progress stays on this page.
            </div>
        </div>

        <!-- RIGHT PANEL: Today's active tasks & priority tracker (interactive checkboxes) -->
        <div class="task-panel">
            <div class="section-title">⭐ Today's Study Missions</div>
            <ul class="task-list">
                <li class="task-item">
                    <span class="task-check"><input type="checkbox"></span>
                    <div class="task-detail">
                        <div class="task-title">Review Mathematics – Functions & Graphs</div>
                        <div class="task-subject">📐 Mathematics | 45 min</div>
                    </div>
                    <span class="task-priority">🔥 High</span>
                </li>
                <li class="task-item">
                    <span class="task-check"><input type="checkbox"></span>
                    <div class="task-detail">
                        <div class="task-title">Physical Science practical questions (work, energy)</div>
                        <div class="task-subject">⚛️ Physical Science | 1 hour</div>
                    </div>
                    <span class="task-priority">⭐ Medium</span>
                </li>
                <li class="task-item">
                    <span class="task-check"><input type="checkbox"></span>
                    <div class="task-detail">
                        <div class="task-title">English: Read prescribed novel & notes</div>
                        <div class="task-subject">📖 English HL | 30 min</div>
                    </div>
                    <span class="task-priority">📌 Normal</span>
                </li>
                <li class="task-item">
                    <span class="task-check"><input type="checkbox"></span>
                    <div class="task-detail">
                        <div class="task-title">Geography: Mapwork and synoptic charts</div>
                        <div class="task-subject">🌍 Geography | 40 min</div>
                    </div>
                    <span class="task-priority">✨ Medium</span>
                </li>
                <li class="task-item">
                    <span class="task-check"><input type="checkbox"></span>
                    <div class="task-detail">
                        <div class="task-title">Life Orientation: Goal setting & exam prep</div>
                        <div class="task-subject">🧠 LO | 25 min</div>
                    </div>
                    <span class="task-priority">📘 Low</span>
                </li>
            </ul>
            <div style="margin-top: 1rem; background: #f2f5f9; border-radius: 1rem; padding: 0.8rem;">
                <div style="font-weight: 600; margin-bottom: 6px;">📌 Custom task reminder (no login)</div>
                <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
                    <label style="flex:2; font-weight: normal;">➕ Add your own study goal: </label>
                    <input type="text" placeholder="e.g., Practice maths past paper" style="flex:3; padding: 8px; border-radius: 40px; border: 1px solid #ccc; background: white;">
                    <span style="font-size: 0.7rem; color: #e67e22;">✍️ write & tick later</span>
                </div>
                <div class="info-note" style="margin-top: 8px;">Use the checkbox to track any custom task – manual entry, fully private.</div>
            </div>
        </div>
    </div>

    <!-- Extra resources + Motivational message for South African students -->
    <div class="motivation-card">
        <div class="quote-text">
            🌟 <strong>"Education is the most powerful weapon"</strong> — Nelson Mandela<br>
            Keep pushing, future leader! Every study session brings you closer to your dreams.
        </div>
        <div class="flag-emojis">🇿🇦 ✨ 📖</div>
    </div>

    <!-- STUDY LOG section: no JS needed, just textarea for personal notes -->
    <div class="study-notes">
        <label for="studyJournal">📝 Study Journal & Reflection (no login, data stays local)</label>
        <textarea id="studyJournal" rows="3" placeholder="Write your study reflections, difficult concepts, or achievements today... E.g., 'I mastered quadratic equations! Next: revise chemical bonding.'"></textarea>
    </div>

    <!-- custom subjects / term planner without JS - just a table with additional subjects to track -->
    <div style="margin-top: 1.8rem;">
        <div class="section-title">🗂️ Subject Tracker (CAPS aligned)</div>
        <div style="overflow-x: auto;">
            <table style="width:100%; border-collapse: collapse; background: #fefaf5; border-radius: 1rem;">
                <thead>
                    <tr style="background: #fae6d2;"><th>Subject</th><th>Exam Date (Q4)</th><th>Topics to revise</th><th>Check when done</th></tr>
                </thead>
                <tbody>
                    <tr><td>Mathematics</td><td>Nov 2026</td><td>Calculus, Stats, Euclidean Geometry</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <tr><td>Physical Science</td><td>Nov 2026</td><td>Electrostatics, Organic Chemistry</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <tr><td>English HL</td><td>Oct/Nov</td><td>Unseen poetry, creative writing</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <tr><td>Geography</td><td>Nov 2026</td><td>Rural/Urban settlement, GIS</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                    <tr><td>History</td><td>Nov 2026</td><td>Civil Rights, Independent Africa</td><td class="checkbox-cell"><input type="checkbox"></td></tr>
                </tbody>
            </table>
        </div>
        <div class="custom-subject-note">
            🧭 <strong>No login & no JavaScript</strong> – All checkboxes work natively in HTML/CSS. Use them to mark completed topics,
            weekly sessions or revision blocks. Refresh the page keeps your ticks? Actually, checkboxes state is preserved until page reload/closed.
            For a persistent tracker across sessions, you'd need local storage (JS), but we designed this as a daily printable / manual tracker.
            Perfect for students who want a simple, private and secure study companion.
        </div>
    </div>

    <!-- progress summary via a simple manual total (NO JS, but we use static representation) -->
    <div class="footer-note">
        <div style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
            <span>✨ Track your daily goals: tick off subjects</span>
            <span>📚 #StudySmart #Matric2026 #SouthAfrica</span>
            <span>⏲️ Recommended: 25 min study + 5 min break (Pomodoro)</span>
        </div>
        <hr style="margin: 0.8rem 0;">
        <div>Study Tracker App – designed for SA learners. No sign-up, no distractions. All your study plans in one clean HTML page.</div>
    </div>
</div>
